# ─── Django ──────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com

# ─── Supabase Postgres (get from Supabase → Settings → Database) ──────────
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432

# ─── Supabase Auth (get from Supabase → Settings → API) ──────────────────
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── NowPayments (get from nowpayments.io → Store Settings) ──────────────
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret

# ─── App URL (your Render backend URL) ───────────────────────────────────
BACKEND_URL=https://your-app.onrender.com

# ─── CORS (your Vercel frontend URL) ─────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
